{
  "singleQuote": true,
  "semi": true,
  "useTabs": false,
  "tabWidth": 2,
  "trailingComma": "all",
  "printWidth": 9999999999999,
  "arrowParens": "avoid",
  "endOfLine": "auto",
  "htmlWhitespaceSensitivity": "ignore",
  "vueIndentScriptAndStyle": true,

  "overrides": [
    {
      "files": "*.vue",
      "options": {
        "singleAttributePerLine": false
      }
    },
    {
      "files": ["*.jsx", "*.tsx"],
      "options": {
        "printWidth": 100,
        "singleAttributePerLine": false
      }
    },
    {
      "files": "**/*.scss",
      "options": {
        "tabWidth": 4
      }
    }
  ]
}