{
  "name": "code-headless",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces",
    "build": "npm run build --workspaces",
    "purge": "npx rimraf --glob \"node_modules\" \"packages/*/node_modules\" \"apps/*/node_modules\" \"package-lock.json\" \"packages/*/package-lock.json\" \"apps/*/package-lock.json\""
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.1"
  }
}
